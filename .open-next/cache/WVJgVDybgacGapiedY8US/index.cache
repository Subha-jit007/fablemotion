{"type":"app","meta":{"headers":{"x-nextjs-stale-time":"300","x-nextjs-prerender":"1","x-next-cache-tags":"_N_T_/layout,_N_T_/page,_N_T_/"}},"html":"<!DOCTYPE html><!--WVJgVDybgacGapiedY8US--><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/ada37db733ba947b.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-8e59c81b2863cb34.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-3981a3d1f3561bd8.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-9f142443d1fd175f.js\" async=\"\"></script><script src=\"/_next/static/chunks/55eb4b32-45b7537a78a1de6a.js\" async=\"\"></script><script src=\"/_next/static/chunks/547-c96185c2a53e6114.js\" async=\"\"></script><script src=\"/_next/static/chunks/711-1cb113e1c3c249a6.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-47eb10b8287b6c20.js\" async=\"\"></script><title>FABLEMOTION — prompt-to-motion studio</title><meta name=\"description\" content=\"Describe a launch video. Watch it assemble live. Render the MP4. Drive it from the web agent or straight from your Claude Code terminal over MCP.\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"grain\"><div hidden=\"\"><!--$--><!--/$--></div><div><nav style=\"display:flex;justify-content:space-between;align-items:center;padding:26px 5vw;position:relative;z-index:5\"><span class=\"serif\" style=\"font-size:24px;letter-spacing:-0.01em\">FABLE<em style=\"color:var(--clay)\">MOTION</em></span><a class=\"btn ghost\" style=\"padding:10px 22px;font-size:14px\" href=\"/studio\">Open studio</a></nav><header style=\"padding:7vh 5vw 10vh;display:grid;grid-template-columns:minmax(0,1.1fr) minmax(0,1fr);gap:5vw;align-items:center\"><div><div class=\"kicker\" data-fade=\"true\">prompt-to-motion studio</div><h1 class=\"serif\" data-reveal=\"true\" style=\"font-size:clamp(52px, 6.6vw, 108px);line-height:1.02;letter-spacing:-0.03em;margin:28px 0 34px;font-weight:400\"><span style=\"display:inline-block;overflow:hidden;vertical-align:top\"><span style=\"display:inline-block;margin-right:0.24em\">Launch</span></span><span style=\"display:inline-block;overflow:hidden;vertical-align:top\"><span style=\"display:inline-block;margin-right:0.24em\">videos,</span></span><br/><span style=\"display:inline-block;overflow:hidden;vertical-align:top\"><span style=\"display:inline-block;margin-right:0.24em\">from</span></span><span style=\"display:inline-block;overflow:hidden;vertical-align:top\"><span style=\"display:inline-block;margin-right:0.24em\">a</span></span><span style=\"display:inline-block;overflow:hidden;vertical-align:top\"><span style=\"display:inline-block;font-style:italic;color:var(--clay)\">sentence.</span></span></h1><p data-fade=\"true\" style=\"font-size:19px;line-height:1.6;max-width:470px;opacity:0.75;margin-bottom:40px\">Describe the video. An agent composes the scenes. Remotion films them live in your browser. One click renders the MP4.</p><div data-fade=\"true\" style=\"display:flex;gap:16px;flex-wrap:wrap\"><a class=\"btn\" href=\"/studio\">Make a video →</a><a href=\"#mcp\" class=\"btn ghost\">No API key? Use your terminal</a></div></div><div data-hero-card=\"true\" style=\"border-radius:20px;overflow:hidden;box-shadow:0 50px 100px rgba(26,23,20,0.28);border:1px solid var(--line);background:#000\"><audio preload=\"metadata\" src=\"data:audio/mp3;base64,/+MYxAAJcAV8AAgAABn//////+/gQ5BAMA+D4Pg+BAQBAEAwD4Pg+D4EBAEAQDAPg++hYBH///hUFQVBUFREDQNHmf///////+MYxBUGkAGIMAAAAP/29Xt6lUxBTUUzLjEwMFVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVV/+MYxDUAAANIAAAAAFVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVVV\"></audio><audio preload=\"metadata\" src=\"data